# =====================================================
# YouTube Content Pipeline - Environment Variables
# =====================================================
# Bu dosyayi `.env` olarak kopyalayin ve degerleri doldurun.
# .env dosyasi asla commit edilmez (.gitignore'da).

# NOTE: LLM steps (topic selection, script writing, Shorts segment picking)
# are performed by the Claude Code session itself (Max plan), not via API.
# So no ANTHROPIC_API_KEY is needed.

# ----- ElevenLabs (TTS) -----
# Dashboard -> Profile -> API key
ELEVENLABS_API_KEY=
# Klonlanmis sesinizin voice_id'si (Voices -> My voice -> ID)
ELEVENLABS_VOICE_ID=
# Model: eleven_multilingual_v2 (Turkce icin en iyi)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ----- YouTube Data API v3 -----
# Google Cloud Console -> APIs -> Credentials -> OAuth client (Desktop app)
# client_secret.json dosyasini proje kokune koy ve burada path'ini ver
YOUTUBE_CLIENT_SECRET_PATH=./client_secret.json
# OAuth refresh token (npm run yt:auth ile uretilir)
YOUTUBE_TOKEN_PATH=./data/.yt-token.json
# Public read API key (trend tarama icin) - OAuth'tan ayri
# Google Cloud Console -> APIs -> Credentials -> Create credentials -> API key
YOUTUBE_API_KEY=

# ----- Pexels (Stok video) -----
# pexels.com/api -> API key
PEXELS_API_KEY=

# ----- Pixabay (Stok video, yedek) -----
# pixabay.com/api/docs -> API key
PIXABAY_API_KEY=

# ----- Reddit API (Trend kaynagi) -----
# reddit.com/prefs/apps -> "script" tipinde app olustur
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=youtube-content-pipeline/0.1 by yourname

# ----- fal.ai (AI gorsel) -----
# fal.ai/dashboard -> API keys
FAL_KEY=

# ----- YouTube Channel Bilgisi (Upload icin) -----
# Hangi kanala yukleneceği - bos birakilirsa OAuth'taki default kanal
YOUTUBE_CHANNEL_ID=

# ----- video-toolkit (OPSIYONEL, cloud GPU) -----
# digitalsamba/claude-code-video-toolkit, LTX2/AceStep/Qwen-Edit gibi gorsel
# ve video uretim adimlarini cloud GPU uzerinden calistirir. Kullanmak isterseniz
# Modal (en kolay, $30/ay free credit) veya RunPod (~$0.44/saat) kurun.
# Detayli env listesi: video-toolkit/.env.example
# MODAL_FLUX2_ENDPOINT_URL=
# MODAL_QWEN3_TTS_ENDPOINT_URL=
# RUNPOD_API_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ----- Pipeline Ayarlari -----
# Uretim ayi (YYYY-MM). Bos birakilirsa su anki ay kullanilir.
PIPELINE_MONTH=
# Maksimum log seviyesi: debug | info | warn | error
LOG_LEVEL=info
# Whisper modeli: tiny | base | small | medium | large
WHISPER_MODEL=medium
# Python interpreter (whisper icin)
PYTHON_BIN=python
